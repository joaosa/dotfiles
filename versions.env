#!/usr/bin/env bash
# Consolidated version pins for all non-Brewfile packages
# Edit this file to update versions. Run ./bootstrap to apply.
# Brewfile manages Homebrew packages. .tool-versions manages asdf versions.
# shellcheck disable=SC2034  # All variables are used by sourcing scripts

# NOTE: Language runtime versions (Node.js, Go) are in .tool-versions
# because asdf reads that file directly for version auto-switching.
# This file covers everything NOT managed by asdf or Brewfile.

# Homebrew installer (pinned commit + SHA256 for reproducibility)
HOMEBREW_INSTALL_COMMIT="5fef4f1a1ed200604720f0ca18c76264d52c75f9"
HOMEBREW_INSTALL_SHA256="1c9db64f27d7487ecf74fe3543b96beb1f78039cc92745c3e825a9a7ccefec80"

# Prezto (pinned commit for reproducibility)
PREZTO_COMMIT="56669270988c5e32422643ec9e0562d1f3c6a0b8"

# Go packages (go install format)
GO_PACKAGES=(
  "github.com/x-motemen/gore/cmd/gore@v0.6.1"
  "github.com/cirocosta/asciinema-edit@v0.2.0"
)

# npm packages (npm install -g format)
NPM_PACKAGES=(
  "@anthropic-ai/claude-code@2.0.8"
)

# Cargo packages (crate:binary format — binary name after colon, omit if same as crate)
CARGO_PACKAGES=(
  "openpgp-card-tools:oct"          # YubiKey/OpenPGP card management
  "openpgp-card-tool-git:oct-git"   # Git signing without gpg-agent
  "qwen-asr-cli:qwen-asr"          # Speech-to-text (Qwen3 ASR)
)

# Downloads with SHA256 integrity verification
# To regenerate checksums: curl -fsSL <URL> | shasum -a 256
KUBECTL_ALIASES_PATH="$HOME/.kubectl_aliases"
KUBECTL_ALIASES_URL="https://raw.githubusercontent.com/ahmetb/kubectl-aliases/7549fa45bbde7499b927c74cae13bfb9169c9497/.kubectl_aliases"
KUBECTL_ALIASES_SHA256="2aa6fa924d84663a17e797e566a8ae3512c94037c2d973203be177b720849ea9"

ASR_MODEL_DIR="$HOME/.local/share/qwen3-asr/Qwen3-ASR-0.6B"
ASR_MODEL_REPO="Qwen/Qwen3-ASR-0.6B"
ASR_MODEL_COMMIT="5eb144179a02acc5e5ba31e748d22b0cf3e303b0"
